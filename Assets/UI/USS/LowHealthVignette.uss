@import url("Shared.uss");

#LowHealthVignette {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    opacity: var(--opacity-zero, 0);
    transition: opacity var(--transition-normal, 0.3s) ease;
    -unity-background-scale-mode: stretch-to-fill;
    background-image: resource("Images/ui_vignette");
    -unity-background-image-tint-color: var(--color-accent-red-dark, rgb(160, 0, 0));
}

#LowHealthVignette.low {
    opacity: var(--opacity-low, 0.45);
}

#LowHealthVignette.critical {
    opacity: var(--opacity-high, 0.85);
}
