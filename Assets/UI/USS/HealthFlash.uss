/* HealthFlash.uss — Phase 22: Full-screen flash overlay */

#HealthFlash {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    picking-mode: ignore;
    -unity-background-scale-mode: stretch-to-fill;
}

#HealthFlash.flash {
    opacity: 1;
    transition: none;
}
