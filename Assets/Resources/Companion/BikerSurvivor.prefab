--- !u!114 &6768075256788150034
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2860618554601681731}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d3baee2a34fd44a43bc3cab85b996368, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CompanionDialogueTrigger
  uniqueID: c9bc101a-3072-48aa-8010-b4dc5bf7dd9d
  interactable: 0
  interactText: "N\xF3i chuy\u1EC7n"
  instantInteraction: 1
  interactableEvents:
    OnInteract:
      m_PersistentCalls:
        m_Calls: []
  stage1Line: "N\xE0y anh b\u1EA1n, t\xF4i c\u1EA7n \xEDt \u0111\u1EA1n. Anh c\xF3
    d\u01B0 40 vi\xEAn kh\xF4ng?"
  stage2Line: "C\u1EA3m \u01A1n \u0111\u1EA1n. Gi\u1EDD t\xF4i c\u1EA7n anh gi\xFAp
    \u2014 v\xE0o 2 ti\u1EC7m kia t\xECm nhu y\u1EBFu ph\u1EA9m gi\xFAp t\xF4i. T\xF4i
    b\u1ECB th\u01B0\u01A1ng kh\xF4ng \u0111i \u0111\u01B0\u1EE3c."
  stage3Line: "Anh l\u1EA5y \u0111\u01B0\u1EE3c nhu y\u1EBFu ph\u1EA9m r\u1ED3i \xE0?
    \u0110\u01B0a cho t\xF4i, r\u1ED3i t\xF4i s\u1EBD \u0111i c\xF9ng anh."
  stage4Line: "T\xF4i c\xF3 th\u1EC3 gi\xFAp anh t\xECm c\xF4ng th\u1EE9c thu\u1ED1c,
    nh\u01B0ng v\u1EDBi \u0111i\u1EC1u ki\u1EC7n l\xE0 anh ph\u1EA3i cho t\xF4i \u0111i
    c\xF9ng."
  stage1InteractText: "N\xF3i chuy\u1EC7n"
  stage2InteractText: "N\xF3i chuy\u1EC7n"
  stage3InteractText: "N\xF3i chuy\u1EC7n"
  stage4InteractText: "N\xF3i chuy\u1EC7n"
