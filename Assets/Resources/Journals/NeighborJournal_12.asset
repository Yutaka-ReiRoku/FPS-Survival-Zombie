  m_Name: NeighborJournal_12
  m_EditorClassIdentifier: Assembly-CSharp::JournalData
  id: 29
  title: "Nh\u1EADt k\xFD h\xE0ng x\xF3m #12 \u2014 Sinh vi\xEAn n\u0103m nh\u1EA5t"
  category: 3
  content: "Tr\u01B0\u1EDDng \u0111\xF3ng c\u1EEDa, k\xFD t\xFAc x\xE1 phong t\u1ECFa.
    M\xECnh v\u1EC1 nh\xE0 nh\u01B0ng nh\xE0 c\u0169ng kh\xF4ng c\xF2n ai. B\u1ED1
    m\u1EB9 \u0111i c\xF4ng t\xE1c ch\u01B0a v\u1EC1. M\xECnh \u1EDF l\u1EA1i c\u0103n
    nh\xE0 n\xE0y m\u1ED9t m\xECnh. \u0110i\u1EC7n c\u1EAFt r\u1ED3i, n\u01B0\u1EDBc
    c\u0169ng y\u1EBFu. M\xECnh t\xECm th\u1EA5y m\u1EA5y cu\u1ED1n nh\u1EADt k\xFD
    c\u1EE7a h\xE0ng x\xF3m trong th\xF9ng r\xE1c \u2014 h\u1ECD b\u1ECF l\u1EA1i
    khi b\u1ECF ch\u1EA1y. M\xECnh s\u1EBD gi\u1EEF l\u1EA1i, ph\xF2ng khi c\xF3
    ai quay v\u1EC1 t\xECm."
  image: {fileID: 0}
  voiceLog: {fileID: 0}
