  m_Script: {fileID: 11500000, guid: 7203cf67233ef0a4b81f63e4fdc64c45, type: 3}
  m_Name: MilitaryRecord_06
  m_EditorClassIdentifier: Assembly-CSharp::JournalData
  id: 41
  title: "B\xE1o c\xE1o qu\xE2n \u0111\u1ED9i #6 \u2014 L\u1EC7nh cu\u1ED1i c\xF9ng
    c\u1EE7a \u0110\u1EA1i t\xE1 Morrison"
  category: 5
  content: "\u0110\u1EA1i t\xE1 Morrison \u0111\xE2y. \u0110\xE2y l\xE0 b\u1EA3n
    ghi cu\u1ED1i c\xF9ng. K\xEDp c\xF4ng binh \u0111\xE3 g\u1EAFn 8 charges \u1EDF
    tr\u1EE5 c\u1EA7u nh\u01B0ng m\u1EA5t b\u1ED9 k\xEDch n\u1ED5 trong l\xFAc r\xFAt
    lui. M\u1ED9t th\xE0nh vi\xEAn k\xEDp b\u1ECB c\u1EAFn v\xE0 bi\u1EBFn ngay trong
    xe. B\u1ED9 k\xEDch n\u1ED5 \u0111\u01B0\u1EE3c c\u1EA5t \u1EDF t\xF2a cao t\u1EA7ng
    g\u1EA7n c\u1EA7u \u2014 t\u1EA7ng tr\xEAn c\xF9ng. N\u1EBFu ai c\xF2n s\u1ED1ng
    nghe \u0111\u01B0\u1EE3c b\u1EA3n ghi n\xE0y: l\u1EA5y b\u1ED9 k\xEDch n\u1ED5,
    k\xEDch ho\u1EA1t qu\u1EA3 bom. \u0110\xE2y l\xE0 l\u1EC7nh cu\u1ED1i c\xF9ng.
    Phong to\u1EA3 \u0111\xE3 th\u1EA5t b\u1EA1i. Bom l\xE0 c\xE1ch duy nh\u1EA5t.
    Morrison, k\xFD."
  image: {fileID: 0}
  voiceLog: {fileID: 0}
